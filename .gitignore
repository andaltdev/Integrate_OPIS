# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Java / Gradle
# -----------------------------------------------------------------------------
.gradle/
build/
target/
bin/
*.class
*.jar
*.war

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.*.example

